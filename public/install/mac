#!/bin/bash
set -e

INSTALL_DIR="$HOME/.dev-dashboard-agent"
DASHBOARD_URL="${1}"
AGENT_TOKEN="${2}"

if [ -z "$AGENT_TOKEN" ] || [ -z "$DASHBOARD_URL" ]; then
  echo "Usage: curl -fsSL <dashboard>/install/mac | bash -s -- <dashboard_url> <agent_token>"
  echo ""
  echo "Get token: Dashboard → Devices → Add Device"
  exit 1
fi

echo "🔧 Dev Dashboard Agent Installer (macOS)"
echo "──────────────────────────────────────────"
echo "Dashboard: $DASHBOARD_URL"
echo "Install:   $INSTALL_DIR"
echo ""

# Dependencies check
command -v node >/dev/null 2>&1 || { echo "❌ Node.js 22+ required. Install: brew install node"; exit 1; }
NODE_VERSION=$(node -v | cut -d'v' -f2 | cut -d'.' -f1)
if [ "$NODE_VERSION" -lt 20 ]; then
  echo "❌ Node.js 20+ required (found v$NODE_VERSION)"
  exit 1
fi
echo "✓ Node.js $(node -v)"

command -v pnpm >/dev/null 2>&1 || {
  echo "📦 Installing pnpm..."
  npm install -g pnpm
}

# Clone / update agent
if [ -d "$INSTALL_DIR" ]; then
  echo "📂 Updating existing agent..."
  cd "$INSTALL_DIR"
  git pull --rebase 2>/dev/null || true
else
  echo "📥 Downloading agent..."
  if [ -d "/opt/dev-dashboard-agent" ]; then
    cp -r /opt/dev-dashboard-agent "$INSTALL_DIR"
  else
    mkdir -p "$INSTALL_DIR"
    curl -fsSL "$DASHBOARD_URL/api/agent/download" -o /tmp/agent.tar.gz 2>/dev/null && \
      tar -xzf /tmp/agent.tar.gz -C "$INSTALL_DIR" && \
      rm /tmp/agent.tar.gz || {
        echo "⚠ Could not download agent package."
        echo "Copy the agent/ directory manually to $INSTALL_DIR"
        exit 1
      }
  fi
fi

cd "$INSTALL_DIR"
pnpm install --frozen-lockfile 2>/dev/null || pnpm install

# Config
cat > "$INSTALL_DIR/.env" <<EOF
DASHBOARD_URL=$DASHBOARD_URL
AGENT_TOKEN=$AGENT_TOKEN
AGENT_NAME=$(scutil --get ComputerName 2>/dev/null || hostname)
AGENT_PORT=3939
PROJECT_PATHS=$HOME/projects,$HOME/Desktop/Projects
EOF

echo "✓ Configuration saved"

# launchd plist
PLIST="$HOME/Library/LaunchAgents/com.devdashboard.agent.plist"
mkdir -p "$HOME/Library/LaunchAgents"

NODE_PATH=$(which node)

cat > "$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.devdashboard.agent</string>
  <key>ProgramArguments</key>
  <array>
    <string>$NODE_PATH</string>
    <string>--import</string>
    <string>tsx</string>
    <string>$INSTALL_DIR/src/index.ts</string>
  </array>
  <key>WorkingDirectory</key>
  <string>$INSTALL_DIR</string>
  <key>KeepAlive</key>
  <true/>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$INSTALL_DIR/agent.log</string>
  <key>StandardErrorPath</key>
  <string>$INSTALL_DIR/agent.error.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>NODE_ENV</key>
    <string>production</string>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
  </dict>
</dict>
</plist>
EOF

launchctl unload "$PLIST" 2>/dev/null || true
launchctl load "$PLIST"

echo ""
echo "──────────────────────────────────────────"
echo "✅ Agent installed and running!"
echo ""
echo "Logs:      tail -f $INSTALL_DIR/agent.log"
echo "Stop:      launchctl unload $PLIST"
echo "Start:     launchctl load $PLIST"
echo "Uninstall: bash $INSTALL_DIR/uninstall.sh"
