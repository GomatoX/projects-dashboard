#!/bin/bash
set -e

INSTALL_DIR="$HOME/.dev-dashboard-agent"
DASHBOARD_URL="${1}"
AGENT_TOKEN="${2}"
SERVICE_NAME="dev-dashboard-agent"
SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"

# If args missing but an existing .env is present, reuse its values.
# This makes the same install URL work as both installer and updater:
#
#   First install: curl ... | bash -s -- <url> <token>
#   Update:        curl ... | bash         (reuses ~/.dev-dashboard-agent/.env)
#
if [ -z "$DASHBOARD_URL" ] || [ -z "$AGENT_TOKEN" ]; then
  if [ -f "$INSTALL_DIR/.env" ]; then
    [ -z "$DASHBOARD_URL" ] && DASHBOARD_URL=$(grep -E '^DASHBOARD_URL=' "$INSTALL_DIR/.env" | head -n1 | cut -d= -f2-)
    [ -z "$AGENT_TOKEN" ]   && AGENT_TOKEN=$(grep -E '^AGENT_TOKEN=' "$INSTALL_DIR/.env" | head -n1 | cut -d= -f2-)
    echo "ℹ Reusing DASHBOARD_URL / AGENT_TOKEN from $INSTALL_DIR/.env"
  fi
fi

if [ -z "$AGENT_TOKEN" ] || [ -z "$DASHBOARD_URL" ]; then
  echo "Usage: curl -fsSL <dashboard>/install/linux | bash -s -- <dashboard_url> <agent_token>"
  echo ""
  echo "Get token: Dashboard → Devices → Add Device"
  exit 1
fi

# Detect install vs update so we can show useful progress
PREV_VERSION=""
if [ -f "$INSTALL_DIR/package.json" ]; then
  PREV_VERSION=$(grep -E '"version"' "$INSTALL_DIR/package.json" | head -n1 | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/')
fi

echo "🔧 Dev Dashboard Agent Installer (Linux)"
echo "──────────────────────────────────────────"
if [ -n "$PREV_VERSION" ]; then
  echo "Mode:      UPDATE (current v$PREV_VERSION)"
else
  echo "Mode:      FRESH INSTALL"
fi
echo "Dashboard: $DASHBOARD_URL"
echo "Install:   $INSTALL_DIR"
echo ""

# Dependencies check
command -v node >/dev/null 2>&1 || { echo "❌ Node.js 22+ required. Install: https://nodejs.org"; exit 1; }
NODE_VERSION=$(node -v | cut -d'v' -f2 | cut -d'.' -f1)
if [ "$NODE_VERSION" -lt 20 ]; then
  echo "❌ Node.js 20+ required (found v$NODE_VERSION)"
  exit 1
fi
echo "✓ Node.js $(node -v)"

command -v pnpm >/dev/null 2>&1 || {
  echo "📦 Installing pnpm..."
  npm install -g pnpm
}

# Stop running agent before swapping files (no-op if not yet installed)
if [ -f "$SERVICE_FILE" ]; then
  echo "🛑 Stopping running agent (if any)..."
  sudo systemctl stop "$SERVICE_NAME" 2>/dev/null || true
fi

# ALWAYS download a fresh tarball. The previous version tried `git pull` here
# but $INSTALL_DIR is not a git repo (it's an extracted tarball), so the
# "update" path silently did nothing.
echo "📥 Downloading latest agent..."
mkdir -p "$INSTALL_DIR"
TAR_TMP=$(mktemp -t dev-dashboard-agent.XXXXXX)
curl -fsSL "$DASHBOARD_URL/api/agent/download" -o "$TAR_TMP" || {
  echo "❌ Could not download agent package from $DASHBOARD_URL/api/agent/download"
  rm -f "$TAR_TMP"
  exit 1
}

# Wipe everything except node_modules / .env / logs so removed-in-newer-version
# files don't linger. Tarball excludes .env, so it would not be overwritten,
# but we still preserve it explicitly here for safety.
echo "🧹 Cleaning previous install (preserving .env, node_modules, logs)..."
find "$INSTALL_DIR" -mindepth 1 -maxdepth 1 \
  ! -name 'node_modules' \
  ! -name '.env' \
  ! -name '.env.local' \
  ! -name 'agent.log' \
  ! -name 'agent.error.log' \
  -exec rm -rf {} +

tar -xzf "$TAR_TMP" -C "$INSTALL_DIR"
rm -f "$TAR_TMP"

cd "$INSTALL_DIR"
pnpm install --frozen-lockfile 2>/dev/null || pnpm install

# Config — only write a fresh .env on first install. On updates we keep the
# existing one so user customizations (PROJECT_PATHS, AGENT_NAME, etc.)
# survive.
CLAUDE_BIN=$(command -v claude 2>/dev/null || true)

if [ ! -f "$INSTALL_DIR/.env" ]; then
  cat > "$INSTALL_DIR/.env" <<EOF
DASHBOARD_URL=$DASHBOARD_URL
AGENT_TOKEN=$AGENT_TOKEN
AGENT_NAME=$(hostname)
AGENT_PORT=3939
PROJECT_PATHS=$HOME/projects
EOF

  if [ -n "$CLAUDE_BIN" ]; then
    echo "CLAUDE_PATH=$CLAUDE_BIN" >> "$INSTALL_DIR/.env"
    echo "✓ Claude CLI: $CLAUDE_BIN"
  else
    echo "⚠ Claude CLI not found in PATH — chat feature disabled until you install it"
  fi

  echo "✓ Configuration created"
else
  echo "✓ Existing .env preserved (delete it and re-run to regenerate)"
fi

# Drop a one-shot updater so the user never has to remember the curl command.
cat > "$INSTALL_DIR/update.sh" <<'UPDATE_EOF'
#!/bin/bash
# Re-runs the installer reusing existing .env values.
set -e
INSTALL_DIR="$HOME/.dev-dashboard-agent"
if [ ! -f "$INSTALL_DIR/.env" ]; then
  echo "❌ $INSTALL_DIR/.env not found — agent does not seem to be installed"
  exit 1
fi
DASHBOARD_URL=$(grep -E '^DASHBOARD_URL=' "$INSTALL_DIR/.env" | head -n1 | cut -d= -f2-)
AGENT_TOKEN=$(grep -E '^AGENT_TOKEN=' "$INSTALL_DIR/.env" | head -n1 | cut -d= -f2-)
if [ -z "$DASHBOARD_URL" ] || [ -z "$AGENT_TOKEN" ]; then
  echo "❌ Could not read DASHBOARD_URL / AGENT_TOKEN from $INSTALL_DIR/.env"
  exit 1
fi
echo "⬆ Updating Dev Dashboard Agent from $DASHBOARD_URL..."
curl -fsSL "$DASHBOARD_URL/install/linux" | bash -s -- "$DASHBOARD_URL" "$AGENT_TOKEN"
UPDATE_EOF
chmod +x "$INSTALL_DIR/update.sh"

# Systemd service
sudo tee "$SERVICE_FILE" > /dev/null <<EOF
[Unit]
Description=Dev Dashboard Agent
After=network.target

[Service]
Type=simple
User=$USER
WorkingDirectory=$INSTALL_DIR
ExecStart=$(which node) --import tsx src/index.ts
Restart=always
RestartSec=5
StandardOutput=append:$INSTALL_DIR/agent.log
StandardError=append:$INSTALL_DIR/agent.error.log
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
EOF

sudo systemctl daemon-reload
sudo systemctl enable "$SERVICE_NAME"
sudo systemctl restart "$SERVICE_NAME"

NEW_VERSION=$(grep -E '"version"' "$INSTALL_DIR/package.json" | head -n1 | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/')

# Wait briefly so the agent has a chance to write its startup banner
sleep 2
BANNER=""
if [ -f "$INSTALL_DIR/agent.log" ]; then
  BANNER=$(grep -E '🔧 Dev Dashboard Agent' "$INSTALL_DIR/agent.log" | tail -n1)
fi

echo ""
echo "──────────────────────────────────────────"
if [ -n "$PREV_VERSION" ] && [ "$PREV_VERSION" != "$NEW_VERSION" ]; then
  echo "✅ Agent updated: v$PREV_VERSION → v$NEW_VERSION"
elif [ -n "$PREV_VERSION" ]; then
  echo "✅ Agent reinstalled (v$NEW_VERSION)"
else
  echo "✅ Agent installed and running (v$NEW_VERSION)"
fi
if [ -n "$BANNER" ]; then
  echo "Running:   $BANNER"
fi
echo ""
echo "Status:    sudo systemctl status $SERVICE_NAME"
echo "Logs:      tail -f $INSTALL_DIR/agent.log"
echo "Update:    bash $INSTALL_DIR/update.sh   (or re-run this same curl command)"
echo "Stop:      sudo systemctl stop $SERVICE_NAME"
echo "Uninstall: bash $INSTALL_DIR/uninstall.sh"
